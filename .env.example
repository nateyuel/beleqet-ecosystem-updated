# =============================================================================
# Beleqet Backend — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit .env to version control.
# =============================================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql://beleqet_user:your_password@localhost:5432/beleqet_db

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Two-Factor Authentication (TOTP)
# Generate with: openssl rand -hex 32 (produces 64 hex chars / 32 bytes for AES-256)
TOTP_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
TOTP_ISSUER=Beleqet
# Separate signing key for 2FA temp/challenge tokens (REQUIRED, must differ from JWT_ACCESS_SECRET)
# Generate with: openssl rand -hex 64
TOTP_TEMP_SECRET=REPLACE_WITH_STRONG_SECRET_64_CHARS

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=-1001234567890

CHAPA_SECRET_KEY=CHASECK_TEST-...
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...
CHAPA_WEBHOOK_SECRET=your_webhook_secret
CHAPA_CALLBACK_URL=http://localhost:4000/api/v1/escrow/callback
CHAPA_RETURN_URL=http://localhost:3000/freelance/payment-success

AWS_S3_BUCKET=beleqet-uploads
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# Cloudflare R2 (preferred when configured; rotate any exposed credentials)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@beleqet.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Beleqet <noreply@beleqet.com>
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM=Beleqet <noreply@beleqet.com>

# Initial admin account used by prisma/seed.ts
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin

BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=your_board_password
